#!/bin/bash
# cc-call — bash-friendly wrapper around cc_client.py for shell consumers.
#
# Usage:
#   cc-call [--timeout SEC] [--retries N] METHOD /api/path  [body via stdin]
#
# Examples:
#   cc-call POST /api/event/batch < body.json
#   echo '{"x":1}' | cc-call --timeout 2 --retries 1 POST /api/event
#   cc-call GET /api/projects
#
# Output:
#   - Response body to stdout (raw text, or JSON if the response was JSON).
#   - Short error tag to stderr when not delivered.
#
# Exit codes:
#   0  delivered (2xx)
#   1  non-retryable 4xx
#   2  5xx or network failure (after retries)
#   3  no track key available
#   4  bad invocation
#
# The track key is loaded by cc_client.py (Keychain first, file
# fallback). It is never placed in argv, env, or output of this script.

set -e

METHOD=""
URL_PATH=""
TIMEOUT=""
RETRIES=""

while [ "$#" -gt 0 ]; do
    case "$1" in
        --timeout) TIMEOUT="$2"; shift 2 ;;
        --retries) RETRIES="$2"; shift 2 ;;
        --*)
            echo "cc-call: unknown flag: $1" >&2
            exit 4
            ;;
        *)
            if [ -z "$METHOD" ]; then
                METHOD="$1"
            elif [ -z "$URL_PATH" ]; then
                URL_PATH="$1"
            else
                echo "cc-call: unexpected positional arg: $1" >&2
                exit 4
            fi
            shift
            ;;
    esac
done

if [ -z "$METHOD" ] || [ -z "$URL_PATH" ]; then
    echo "usage: cc-call [--timeout SEC] [--retries N] METHOD /api/path  [body via stdin]" >&2
    exit 4
fi

# Read body from stdin only when stdin is redirected (pipe / heredoc /
# file). When run interactively we don't block waiting for keyboard input.
BODY=""
if [ ! -t 0 ]; then
    BODY=$(cat)
fi

CC_METHOD="$METHOD" \
CC_PATH="$URL_PATH" \
CC_BODY="$BODY" \
CC_TIMEOUT="$TIMEOUT" \
CC_RETRIES="$RETRIES" \
python3 - <<'PY'
import json, os, sys

sys.path.insert(0, os.path.expanduser("~/.claude/hooks"))
import cc_client

method = os.environ["CC_METHOD"]
path = os.environ["CC_PATH"]
body_raw = os.environ.get("CC_BODY", "")

body = None
if body_raw:
    try:
        body = json.loads(body_raw)
    except Exception:
        body = body_raw

kwargs = {"body": body}
timeout_env = os.environ.get("CC_TIMEOUT", "")
if timeout_env:
    try:
        kwargs["timeout"] = int(timeout_env)
    except ValueError:
        sys.stderr.write(f"cc-call: invalid --timeout: {timeout_env}\n")
        sys.exit(4)
retries_env = os.environ.get("CC_RETRIES", "")
if retries_env:
    try:
        kwargs["retries"] = int(retries_env)
    except ValueError:
        sys.stderr.write(f"cc-call: invalid --retries: {retries_env}\n")
        sys.exit(4)

result = cc_client.request(method, path, **kwargs)

resp_body = result.get("body")
if resp_body is not None:
    if isinstance(resp_body, (dict, list)):
        sys.stdout.write(json.dumps(resp_body))
    else:
        sys.stdout.write(str(resp_body))
    sys.stdout.write("\n")

err = result.get("error")
if err:
    sys.stderr.write(f"cc-call: {err}\n")

if result.get("delivered"):
    sys.exit(0)
if err == "no_track_key":
    sys.exit(3)
status = result.get("status")
if status is not None and 400 <= status < 500:
    sys.exit(1)
sys.exit(2)
PY
