#!/usr/bin/env bash
#
# safe-git — wrapper that intercepts dangerous `git` invocations before
# they reach the real binary. Symlinked into ~/bin/git so PATH lookup
# resolves here first; we forward everything safe to the real git.
#
# Why a wrapper, not a git hook: git has no `pre-add` hook, and a
# `pre-commit` hook can't tell whether files were staged via `-A` or by
# explicit list (the index has the files, not the flags that put them
# there). The only place we can refuse `git add -A` at the binary level
# is between the shell and git itself — that's this wrapper.
#
# Rules enforced:
#   1. `git add -A` (any spelling) — refused.
#   2. `git add .`  — refused.
#   3. Bare `git add` — refused (must be chained with commit; see #4).
#   4. `git add` invocations that aren't combined with `git commit -m`
#      in the SAME shell command — refused. This forces atomic
#      stage+commit and prevents another agent / parallel session
#      from sneaking files into the index between two separate calls.
#   5. `git commit` (or `git commit -a`) without a preceding
#      `git add <files>` in the same command — refused. Forces
#      explicit file lists; bare `git commit` could ship whatever was
#      already staged from a prior turn.
#
# Bypass: prefix the command with `GIT_UNSAFE_STAGE=1` to disable all
# of the above for that single invocation. Logged to
# ~/.claude/git-bypass.log so it's not silent. Use this for legit
# imports of large folders.
#
# All other `git` invocations (status, diff, log, push, etc.) pass
# through unchanged.

set -eu

# Locate the real git. We chase PATH and skip ourselves so we can't
# infinite-loop. Hard-coded fallbacks cover the homebrew + system
# locations on macOS and Linux.
WRAPPER_PATH="$(readlink -f "$0" 2>/dev/null || python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$0")"
find_real_git() {
    local IFS=':'
    for dir in $PATH; do
        local candidate="$dir/git"
        [ -x "$candidate" ] || continue
        local resolved="$(readlink -f "$candidate" 2>/dev/null || python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$candidate")"
        [ "$resolved" = "$WRAPPER_PATH" ] && continue
        echo "$candidate"
        return 0
    done
    for hard in /opt/homebrew/bin/git /usr/local/bin/git /usr/bin/git; do
        [ -x "$hard" ] && { echo "$hard"; return 0; }
    done
    return 1
}

REAL_GIT="$(find_real_git || true)"
if [ -z "${REAL_GIT:-}" ]; then
    echo "safe-git: cannot find real git binary on PATH or in standard locations" >&2
    exit 127
fi

# Bypass — log the exception, then exec the real git directly.
if [ "${GIT_UNSAFE_STAGE:-}" = "1" ]; then
    LOG="$HOME/.claude/git-bypass.log"
    mkdir -p "$(dirname "$LOG")" 2>/dev/null || true
    {
        printf '[%s] cwd=%s argv=' "$(date '+%Y-%m-%d %H:%M:%S')" "$(pwd)"
        for a in "$@"; do printf '%q ' "$a"; done
        printf '\n'
    } >> "$LOG" 2>/dev/null || true
    exec "$REAL_GIT" "$@"
fi

# Detect the subcommand (first non-option arg). Skip global flags like
# `git -c foo=bar add ...` so the rules still apply.
SUBCMD=""
i=1
while [ $i -le $# ]; do
    eval "arg=\${$i}"
    case "$arg" in
        -*) ;;                  # global flag, keep scanning
        *) SUBCMD="$arg"; break ;;
    esac
    i=$((i + 1))
done

# Only interesting subcommands: add, commit, reset. Everything else passes through.
case "$SUBCMD" in
    add|commit|reset) ;;
    *) exec "$REAL_GIT" "$@" ;;
esac

# Reconstruct the *original shell command line* if available. Three
# sources, tried in this order:
#
#   1. /proc/$PPID/cmdline on Linux — has the pipeline literally.
#   2. ~/.cache/safe-git-cmd-<ppid> written by the shell-init hook
#      (meirpro-dotfiles/shell/safe-git-hook.sh). This is how macOS
#      interactive shells expose what the user typed — `ps -o command=`
#      on the shell's own PID only shows `-bash`/`-zsh`, not the
#      pipeline being executed. The hook captures `history 1` on every
#      DEBUG trap (bash) or via `preexec` (zsh) and writes it to a
#      per-shell file. We trust the file only if its mtime is fresh
#      (≤ 10 seconds) so a stale capture from a prior pipeline can't
#      let a split call sneak through. We walk the PID ancestry so
#      that subshell invocations like `(git add foo && git commit bar)`
#      still find the outer shell's capture.
#   3. macOS fallback — `ps -o command= -p $PPID`. This works for
#      `bash -c '<pipeline>'` invocations because the pipeline is the
#      bash-c argv literally. Used by Claude Code's Bash tool and any
#      shell-script invocation; doesn't help interactive shells.
#
# Without any of these we conservatively return nothing, which causes
# the rule checks to NOT fire (allow) — the wrapper's job is to catch
# obvious foot-guns, not to deny every command when introspection
# fails.
get_parent_cmdline() {
    local ppid="$PPID"
    [ -z "$ppid" ] && return 1

    # 1. Linux: PPID's cmdline shows the full pipeline.
    if [ -r "/proc/$ppid/cmdline" ]; then
        tr '\0' ' ' < "/proc/$ppid/cmdline"
        return 0
    fi

    # 2. Shell-init hook capture. Walk ancestors so subshells inherit
    #    the outer shell's typed line.
    local now p hook_file mtime age
    now="$(date +%s 2>/dev/null)"
    p="$ppid"
    while [ -n "$p" ] && [ "$p" != "1" ] && [ "$p" != "0" ]; do
        hook_file="$HOME/.cache/safe-git-cmd-$p"
        if [ -f "$hook_file" ] && [ -n "$now" ]; then
            # macOS stat (-f %m) with Linux stat (-c %Y) fallback.
            mtime="$(stat -f %m "$hook_file" 2>/dev/null || stat -c %Y "$hook_file" 2>/dev/null)"
            if [ -n "$mtime" ]; then
                age=$((now - mtime))
                if [ "$age" -ge 0 ] && [ "$age" -le 10 ]; then
                    cat "$hook_file" 2>/dev/null
                    return 0
                fi
            fi
        fi
        # Walk one step up the process tree.
        p="$(ps -o ppid= -p "$p" 2>/dev/null | tr -d ' ')"
    done

    # 3. macOS PS fallback — works for `bash -c '<pipeline>'`.
    if command -v ps >/dev/null 2>&1; then
        ps -ww -o command= -p "$ppid" 2>/dev/null
        return 0
    fi
    return 1
}

PARENT_CMD="$(get_parent_cmdline 2>/dev/null || true)"

deny() {
    # $1 = reason, $2 = explanation, remaining args = original git argv
    local reason="$1" explain="$2"
    shift 2
    cat >&2 <<EOF
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
 git safety wrapper REFUSED this command.

 Reason: $reason

$explain

 Bypass (use sparingly):
   GIT_UNSAFE_STAGE=1 git $(printf '%q ' "$@" | sed 's/ $//')

   Note: env-var prefix only applies to the FIRST command. To bypass
   an \`add && commit\` chain, wrap both in one bash -c:
     GIT_UNSAFE_STAGE=1 bash -c 'git add <file> && git commit -m "msg"'

   Or use bash -c WITHOUT bypass — the wrapper sees the pipeline in
   bash's argv and allows the chain natively:
     bash -c 'git add <file> && git commit -m "msg"'

 Disable wrapper entirely:
   /opt/homebrew/bin/git ...   # call real git by full path
   # or remove ~/bin/git (the symlink) — the rule lives in
   # ~/Documents/GitHub/meirpro-dotfiles/git/safe-git
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
EOF
    exit 64  # EX_USAGE
}

# ─────────────────────────────────────────────────────────────────
# Rule 1+2+3+4: subcommand == add
# ─────────────────────────────────────────────────────────────────
if [ "$SUBCMD" = "add" ]; then
    # Walk add's args looking for forbidden tokens.
    saw_files=0
    j=1
    while [ $j -le $# ]; do
        eval "a=\${$j}"
        case "$a" in
            add) ;;                              # the subcommand itself
            -A|--all|--no-ignore-removal) deny "git add -A is forbidden — stage explicit file paths." \
                "Why: -A stages every changed file in the tree, including ones edited by other parallel agents or generated artifacts. Stage by name:
   git add path/to/file1 path/to/file2 && git commit -m \"msg\"" "$@" ;;
            .)                                    deny "git add . is forbidden — stage explicit file paths." \
                "Why: '.' stages everything under the current directory, including unrelated changes you didn't make. Stage by name:
   git add path/to/file1 path/to/file2 && git commit -m \"msg\"" "$@" ;;
            -*) ;;                                # other flags (-p, --intent-to-add, etc.) pass
            *) saw_files=1 ;;                     # an explicit path
        esac
        j=$((j + 1))
    done

    if [ $saw_files -eq 0 ]; then
        deny "bare 'git add' with no file arguments." \
            "Why: nothing to stage. If you meant 'add everything', that's exactly what's forbidden — stage by explicit name:
   git add path/to/file1 path/to/file2 && git commit -m \"msg\"" "$@"
    fi

    # Atomicity: somewhere in the parent shell command we need the
    # pattern `git add <stuff> && <stuff> git commit` where the gaps
    # contain no shell-statement separators (`;`, `|`). Env-var
    # prefixes (`PATH=foo git commit`) are intentionally allowed —
    # otherwise `PATH="$HOME/bin:$PATH" git add foo && PATH=... git
    # commit` would falsely fail. `&` is allowed as a single
    # character (it's `&&` we care about); the regex requires the
    # full `&&` literal as the chain operator.
    if [ -n "$PARENT_CMD" ]; then
        if [[ "$PARENT_CMD" =~ git[[:space:]]+add[[:space:]]+[^\;\|]*\&\&[^\;\|]*git[[:space:]]+commit ]]; then
            : # OK — chained add ... && ... git commit somewhere
        else
            deny "'git add' must be chained with 'git commit -m \"...\"' in the same shell command." \
                "Why: a separate 'git add' invocation lets a parallel agent slip files into the index between your stage and your commit. Combine them:
   git add path/to/file1 path/to/file2 && git commit -m \"msg\"" "$@"
        fi
    fi
fi

# ─────────────────────────────────────────────────────────────────
# Rule 5: subcommand == commit
# ─────────────────────────────────────────────────────────────────
if [ "$SUBCMD" = "commit" ]; then
    # Detect whether this is the COMMIT half of an `add ... && commit`
    # one-liner (allowed) or a bare `git commit` (forbidden). Rule:
    # parent shell command must contain `git add ` BEFORE this commit.
    # Also reject `git commit -a` outright — that's the same foot-gun
    # as `add -A`.
    for a in "$@"; do
        case "$a" in
            -a|--all|-am|-am*|-a*m|-Am)
                deny "'git commit -a' is forbidden — it's 'git add -A' in disguise." \
                    "Why: -a auto-stages every modified tracked file, exactly the over-staging we banned. Stage by name:
   git add path/to/file1 path/to/file2 && git commit -m \"msg\"" "$@" ;;
        esac
    done

    if [ -n "$PARENT_CMD" ]; then
        # Same regex as the add side — `git add ... && ... git commit`
        # with no shell separators (`;`, `|`) between. Env-var
        # prefixes between `&&` and `git commit` are allowed.
        if [[ "$PARENT_CMD" =~ git[[:space:]]+add[[:space:]]+[^\;\|]*\&\&[^\;\|]*git[[:space:]]+commit ]]; then
            : # OK
        else
            deny "'git commit' must be preceded by 'git add <files>' in the same shell command." \
                "Why: a bare 'git commit' ships whatever was staged on a prior turn — possibly by another agent. Combine stage + commit:
   git add path/to/file1 path/to/file2 && git commit -m \"msg\"" "$@"
        fi
    fi
fi

# ─────────────────────────────────────────────────────────────────
# Rule 6: subcommand == reset
# ─────────────────────────────────────────────────────────────────
# `git reset --hard` discards uncommitted working-tree changes
# silently. When multiple Claude sessions or agents share a checkout
# (the normal case in this repo), one agent's "fast-forward to merged
# origin" can blow away another agent's in-flight WIP — exactly the
# pattern that wiped 300+ lines of manifest code on 2026-05-24 when
# a parallel agent ran `git reset --hard origin/staging/partition-done`
# after merging PR #85. Refuse `reset --hard` whenever the working
# tree (or index) has uncommitted changes; force the caller to deal
# with the WIP explicitly first.
if [ "$SUBCMD" = "reset" ]; then
    saw_hard=0
    for a in "$@"; do
        case "$a" in
            --hard) saw_hard=1 ;;
        esac
    done

    if [ "$saw_hard" = "1" ]; then
        # Check for any uncommitted change: staged, unstaged, OR
        # untracked. Untracked matters because `reset --hard <ref>`
        # itself doesn't delete untracked files, BUT a typical
        # "clean slate" sequence pairs it with `git clean -fd` which
        # does — so we surface the dirty state regardless and let
        # the caller make an informed choice.
        DIRTY="$("$REAL_GIT" status --porcelain 2>/dev/null || true)"
        if [ -n "$DIRTY" ]; then
            COUNT=$(printf '%s\n' "$DIRTY" | wc -l | tr -d ' ')
            FILES="$(printf '%s\n' "$DIRTY" | head -6 | sed 's/^/   /')"
            EXTRA=""
            if [ "$COUNT" -gt 6 ]; then
                EXTRA="$(printf '%s\n' "   ... and $((COUNT - 6)) more")"
            fi
            deny "'git reset --hard' with uncommitted changes in the working tree." \
                "Why: --hard silently throws away unstaged + staged work. If a parallel agent / sibling session is mid-edit on these files, you would erase their WIP without warning.

 Dirty files ($COUNT):
$FILES
$EXTRA

 Resolve first:
   1. If the WIP is yours and unneeded:    git stash -u   (then 'git stash drop' later — NOT 'git stash pop' if you've already reset)
   2. If you want it to survive:           git stash -u && git reset --hard <ref> && git stash pop
   3. If you don't know whose WIP it is:   stop and ask the user — another session may be active." "$@"
        fi
    fi
fi

# All checks passed — forward to the real git.
exec "$REAL_GIT" "$@"
